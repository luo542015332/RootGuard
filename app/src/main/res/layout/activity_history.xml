<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#1A1A2E">

    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="#16213E" android:titleTextColor="#FFFFFF"/>

    <TextView android:id="@+id/tvStats" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="16dp" android:textColor="#00D9FF" android:textSize="13sp" android:background="#0D1B2A"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp">

        <Spinner android:id="@+id/spinnerGame" android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:background="#2A2A4A" android:popupBackground="#1A1A2E"/>

        <Button android:id="@+id/btnExportCsv" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="导出CSV" android:textSize="12sp" android:backgroundTint="#4A90D9" android:layout_marginStart="8dp"/>
        <Button android:id="@+id/btnClearOld" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="清理30天+" android:textSize="12sp" android:backgroundTint="#FF5252" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerView"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <TextView android:id="@+id/tvEmpty" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:text="暂无记录" android:textColor="#666666" android:textSize="16sp" android:gravity="center" android:visibility="gone"/>

</LinearLayout>