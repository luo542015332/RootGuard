{
    name: ["MT-Syntax", ".mtsx"]
    hide: true
    styles: [
        "function" > "operator"
        "flags_B" > "meta", @B
        "flags_I" > "meta", @I
        "flags_U" > "meta", @U
        "flags_S" > "meta", @S
        "flags_BI" > "meta", @BI
        "flags_BU" > "meta", @BU
        "flags_BS" > "meta", @BS
        "flags_IU" > "meta", @IU
        "flags_IS" > "meta", @IS
        "flags_US" > "meta", @US
        "flags_BIU" > "meta", @BIU
        "flags_BIS" > "meta", @BIS
        "flags_BUS" > "meta", @BUS
        "flags_IUS" > "meta", @IUS
        "flags_BIUS" > "meta", @BIUS
        "flags_CLEAR" > "meta"
        "keyword_deprecated" > "keyword", @IS
        "colorBaseLight", #000000#0000, #000000#FFFFFF, @B
        "colorBaseDark", #A9B7C6#2B2B2B, #A9B7C6#0000, @B
        "underline", #NULL, #NULL, @U
        "directive" > "comment" @B
    ]
    comment: {startsWith: "//", addToContains: false}
    contains: [
        {match: /(?mi)^[ \t]*\/\/[ \t]*require[ \t]+MT[ \t]*(>=?)[ \t]*(\d{8}|\d\.\d{1,3}\.\d{1,3}|(\S+))[ \t]*$/, 0: "directive", 3: "error"}
        {
            group: link
            style: "directive"
            contains: [
                {match: /(?m)^[^\S\n]*#/}
                {group: select, contains: [
                    {match: /(else|endif)(\b|$)/}
                    {group: link, contains: [
                            {match: /(if|elif)\b/}
                            {match: /[^\S\n]+/}
                            {match: /MT\b/, 0: "operator"}
                            {match: /[^\S\n]+/}
                            {match: /([<>]=?|[!=]=)/, 1: "operator"}
                            {match: /[^\S\n]+/}
                            {match: /(\d{8}|\d\.\d{1,3}\.\d{1,3})\b/, 1: "operator"}
                    ]}
                    {match: /error(?:[^\S\n]+|$)(.*)/, 1: "string"}
                    {match: /[^\S\n]*(.+)/, 0: "error"} // 未知指令标记为error
                ]}
                {match: /[^\S\n]*(.+)/, 0: "error"} // 后面多出来的代码标记为error
            ]
        }
        {match: "//.*", 0: "comment"}
        {builtin: #JAVA_DOUBLE_QUOTED_STRING#}
        // regex
        {
            start: {match: /\//, 0: "meta"}
            end: {match: /(?m)\/|$/, 0: "meta"}
            style: "string"
            contains: [
                {match: /\\\//, 0: "strEscape"}
            ]
        }
        {match: /(?<=:\s{0,10})#[0-9A-Z_]+#/, 0: "constant"} // built-in
        {match: /(?i)(#([A-F0-9]{3,8}|NULL)(?:[#$]([A-F0-9]{3,8}|NULL))?\b)(?:\s*,?\s*(#([A-F0-9]{3,8}|NULL)(?:[#$]([A-F0-9]{3,8}|NULL))?\b))?/,
                1: "parseColor(2,3,HEX,colorBaseLight)"
                4: "parseColor(5,6,HEX,colorBaseDark)"
                2: "underline"
                3: "underline"
                5: "underline"
                6: "underline"
        }
        {match: /\b(?:0|[1-9][0-9]*)\b/, 0: "number"} // regex group index
        {match: /\b(?:true|false)\b/, 0: "number"} // bool
        {match: /\b(group)\b[ \t]*(?::[ \t]*(/ + keywordsToRegex("link linkAll select") + /)?)?/, 1: "keyword", 2: "number"} // group
        {match: /\b(?:keywordsToRegex)\b/, 0: "function"}

        {match: /@(?:B)\b/, 0: "flags_B"}
        {match: /@(?:I)\b/, 0: "flags_I"}
        {match: /@(?:U)\b/, 0: "flags_U"}
        {match: /@(?:S)\b/, 0: "flags_S"}
        {match: /@(?:BI|IB)\b/, 0: "flags_BI"}
        {match: /@(?:BU|UB)\b/, 0: "flags_BU"}
        {match: /@(?:BS|SB)\b/, 0: "flags_BS"}
        {match: /@(?:IU|UI)\b/, 0: "flags_IU"}
        {match: /@(?:IS|SI)\b/, 0: "flags_IS"}
        {match: /@(?:US|SU)\b/, 0: "flags_US"}
        {match: /@/ + keywordsToRegex("BIU BUI IBU IUB UBI UIB"), 0: "flags_BIU"}
        {match: /@/ + keywordsToRegex("BIS BSI IBS ISB SBI SIB"), 0: "flags_BIS"}
        {match: /@/ + keywordsToRegex("BUS BSU UBS USB SBU SUB"), 0: "flags_BUS"}
        {match: /@/ + keywordsToRegex("IUS ISU UIS USI SIU SUI"), 0: "flags_IUS"}
        {match: /@/ + keywordsToRegex("BIUS BISU BUIS BUSI BSIU BSUI IBUS IBSU IUBS IUSB ISBU ISUB UBIS UBSI UIBS UISB USBI USIB SBIU SBUI SIBU SIUB SUBI SUIB"), 0: "flags_BIUS"}
        {match: /@_\b/, 0: "flags_CLEAR"}
        {match: /@\w+/, 0: "error"}

        {match: keywordsToRegex(
                "match name comment insertSpace contains start end startsWith endsWith builtin"
                "matchEndFirst mustMatchEnd codeFormatter codeShrinker lineBackground ignoreCase hide"
                "addToContains number iSuffixes fSuffixes recordAllGroups defines include endPriority"
                "style styles childrenStyle bracketPairs"
            ), 0: "keyword"
        }
        {match: /<EndMatcher>/, 0: "keyword"}
        {match: /(?i)=> *FAIL\b/, 0: "keyword2"}
        {match: /colors?/, 0: "keyword_deprecated"} // 建议使用 style 代替 color
    ]
}