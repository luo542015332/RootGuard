{
    name: ["Regex"]
    styles: [
        "default", #EE000000, #EED0D0D0
        "escape", #067D17, #6A8759
        "keyword", #1750EB, #6897BB
        "startEnd", #871094, #9876AA
        "class", #808000, #808000
    ]
    bracketPairs: ["[]", "()"]
    hide: true
    defines: [
        "escapes": [
            {match: /\\0[0-7]{1,3}/}
            {match: /\\c./, 0: "escape"}
            {match: /\\k<[0-9A-Za-z]+>/, 0: "escape"}
            {match: /(?i)\\p\{.*?\}/, 0: "escape"}

            // HighSurrogate+LowSurrogate  \uD800-DBFFuDC00-DFFF
            {match: /(?i)\\uD[89AB][0-9A-F]{2}uD[CDEF][0-9A-F]{2}/, 0: "escape"}
            {match: /(?i)\\u[0-9a-f]{4}/, 0: "escape"}

            {match: /\\x[0-9A-Fa-f]{2}/, 0: "escape"}
            {match: /\\x\{[0-9A-Fa-f]+\}/, 0: "escape"}

            // {match: /\\[1-9ABDGHRSVWZabdefhnrstvwz]/, 0: "escape"}
            {match: /\\[0CEFIJKLMNOPQTUXYcgijklmopquxy]/, 0: "error"}
            {match: /\\./, 0: "escape"}
        ]
    ]
    contains: [
        // 转义类
        {include: "escapes"}

        // 元字符
        {match: /[.*+?|]/, 0: "keyword"}
        {match: /[$^]/, 0: "startEnd"}

        // (?:pattern) (?=pattern) (?!pattern) (?<=pattern) (?<!pattern)
        {match: /\(/ + /(\?[:=!]|\?<[=!]|\?<([a-zA-Z][a-zA-Z0-9]*)>)/, 1: "keyword", 2: "string"}

        // {n,m}
        {match: /\{(\d+)(,(\d+)?)?\}/, 0: "operator"}
        {match: /[{}]/, 0: "error"}

        // []
        {
            // 开头和结尾的 - 为普通字符
            start: {match: /(\[\^?)-?/, 1: "class"}
            end: {match: /-?(\])/, 1: "class"}
            contains: [
                // 这些转义不能在[]里面
                {match: /\\[1-9ABGPRZbkz]/, 0: "error"}
                {include: "escapes"}
                {match: /-/, 0: "comment"}
            ]
        }

    ]
}
